<Window x:Class="ToyStore.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация" 
        Height="400" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="#2C3E50">
        <Grid Width="350" Height="280">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Логотип или название -->
            <TextBlock Grid.Row="1" Text="🧸 МИР ИГРУШЕК" 
                       FontSize="22" FontWeight="Bold" 
                       Foreground="White" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,5"/>

            <TextBlock Grid.Row="2" Text="Вход в систему" 
                       FontSize="14" 
                       Foreground="#BDC3C7" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,25"/>

            <!-- Поле Логин -->
            <TextBox x:Name="LoginBox" 
                     Grid.Row="3"
                     FontSize="14"
                     Padding="12"
                     Margin="0,5"
                     Background="White"
                     Foreground="#333"/>

            <!-- Поле Пароль -->
            <PasswordBox x:Name="PasswordBox" 
                         Grid.Row="4"
                         FontSize="14"
                         Padding="12"
                         Margin="0,5"
                         Background="White"/>

            <!-- Кнопка Войти -->
            <Button x:Name="LoginBtn" 
                    Grid.Row="5"
                    Content="ВОЙТИ"
                    FontSize="16"
                    FontWeight="Bold"
                    Background="#27AE60"
                    Foreground="White"
                    Padding="12"
                    Margin="0,20,0,5"
                    BorderThickness="0"
                    Cursor="Hand"/>

            <!-- Кнопка Гость -->
            <Button x:Name="GuestBtn" 
                    Grid.Row="6"
                    Content="ПРОДОЛЖИТЬ КАК ГОСТЬ"
                    FontSize="12"
                    Background="Transparent"
                    Foreground="#7F8C8D"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,5,0,0"/>

            <!-- Ошибка -->
            <TextBlock x:Name="ErrorText" 
                       Grid.Row="7"
                       Foreground="#E74C3C"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0"
                       Visibility="Collapsed"
                       FontSize="12"/>
        </Grid>
    </Grid>
</Window>