<Window x:Class="BikeStore.Views.OrderDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Заказ" 
        Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Background="#ECF0F1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Информация о заказе" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <TextBlock Grid.Row="1" Text="Клиент:" FontWeight="Bold" Margin="0,5"/>
            <ComboBox x:Name="UserBox" Grid.Row="2" Margin="0,0,0,10" Padding="8" DisplayMemberPath="FullName" SelectedValuePath="Id"/>

            <TextBlock Grid.Row="3" Text="Статус:" FontWeight="Bold" Margin="0,5"/>
            <ComboBox x:Name="StatusBox" Grid.Row="4" Margin="0,0,0,10" Padding="8" DisplayMemberPath="Name" SelectedValuePath="Id"/>

            <TextBlock Grid.Row="5" Text="Адрес выдачи:" FontWeight="Bold" Margin="0,5"/>
            <TextBox x:Name="AddressBox" Grid.Row="6" Margin="0,0,0,10" Padding="8"/>

            <TextBlock Grid.Row="7" Text="Дата выдачи:" FontWeight="Bold" Margin="0,5"/>
            <DatePicker x:Name="DeliveryDatePicker" Grid.Row="8" Margin="0,0,0,10"/>

            <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button x:Name="SaveBtn" Content="💾 Сохранить" Background="#27AE60" Foreground="White" Padding="30,10" Margin="10" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="CancelBtn" Content="❌ Отмена" Background="#95A5A6" Foreground="White" Padding="30,10" Margin="10" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>