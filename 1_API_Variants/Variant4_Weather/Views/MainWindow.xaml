<Window x:Class="YourApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🌤️ Погода" 
        Height="500" Width="600"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#2C3E50">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A252F" Padding="20">
            <TextBlock Text="🌤️ Погода в городе" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <Border Grid.Row="1" Background="White" Padding="15" Margin="20,20,20,10" CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="CityBox" Grid.Column="0" FontSize="14" Padding="10" Margin="0,0,10,0" ToolTip="Введите город"/>
                <Button x:Name="SearchBtn" Grid.Column="1" Content="🔍 УЗНАТЬ" Background="#3498DB" Foreground="White" FontSize="14" FontWeight="Bold" Padding="20,10" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>

        <Border x:Name="WeatherCard" Grid.Row="2" Background="#34495E" CornerRadius="10" Margin="20" Padding="20" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="CityText" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <Image x:Name="WeatherIcon" Grid.Column="1" Width="50" Height="50"/>
                </Grid>

                <TextBlock x:Name="TempText" Grid.Row="1" FontSize="36" FontWeight="Bold" Foreground="#4CAF50"/>
                <TextBlock x:Name="DescText" Grid.Row="2" FontSize="14" Foreground="#BDC3C7"/>
                <TextBlock x:Name="DetailsText" Grid.Row="3" FontSize="12" Foreground="#95A5A6" Margin="0,10,0,0"/>
            </Grid>
        </Border>

        <Border Grid.Row="4" Background="#1A252F" Padding="10">
            <TextBlock x:Name="StatusText" Text="Введите город" Foreground="#BDC3C7" FontSize="12" HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>