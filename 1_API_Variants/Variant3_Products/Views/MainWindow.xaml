<Window x:Class="YourApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🛒 Товары" 
        Height="700" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <DataTemplate x:Key="ProductCardTemplate">
            <Border Background="White" CornerRadius="8" Margin="5" Padding="10" BorderBrush="#DDD" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Image Source="{Binding ImageUrl}" Width="80" Height="80" Stretch="Uniform" Margin="0,0,10,0"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding DisplayText}" FontSize="12" Foreground="#4CAF50" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Description}" FontSize="10" Foreground="#666" TextWrapping="Wrap" MaxHeight="40"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF5722" Padding="20">
            <TextBlock Text="🛒 Каталог товаров" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <Border Grid.Row="1" Background="White" Padding="15" Margin="10">
            <Button x:Name="LoadBtn" Content="📦 ЗАГРУЗИТЬ ТОВАРЫ" Background="#FF5722" Foreground="White" FontSize="14" FontWeight="Bold" Padding="20,10" HorizontalAlignment="Center" BorderThickness="0" Cursor="Hand"/>
        </Border>

        <ListBox x:Name="ResultsList" Grid.Row="2" Margin="10" ItemTemplate="{StaticResource ProductCardTemplate}"/>

        <Border Grid.Row="3" Background="#FF5722" Padding="10">
            <TextBlock x:Name="StatusText" Text="Нажмите кнопку для загрузки" Foreground="White" FontSize="12"/>
        </Border>
    </Grid>
</Window>