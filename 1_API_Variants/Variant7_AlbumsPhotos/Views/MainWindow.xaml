<Window x:Class="YourApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🖼️ Фотоальбомы" 
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <DataTemplate x:Key="AlbumCardTemplate">
            <Border Background="White" CornerRadius="8" Margin="5" Padding="10" BorderBrush="#DDD" BorderThickness="1" Cursor="Hand">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding DisplayText}" FontSize="11" Foreground="Gray"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1ABC9C" Padding="20">
            <TextBlock Text="🖼️ Фотоальбомы" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <Border Grid.Row="1" Background="White" Padding="15" Margin="10">
            <Button x:Name="LoadBtn" Content="📷 ЗАГРУЗИТЬ АЛЬБОМЫ" Background="#1ABC9C" Foreground="White" FontSize="14" FontWeight="Bold" Padding="20,10" HorizontalAlignment="Center" BorderThickness="0" Cursor="Hand"/>
        </Border>

        <ListBox x:Name="AlbumsList" Grid.Row="2" Margin="10" ItemTemplate="{StaticResource AlbumCardTemplate}"/>

        <Border Grid.Row="3" Background="#1ABC9C" Padding="10">
            <TextBlock x:Name="StatusText" Text="Нажмите кнопку для загрузки" Foreground="White" FontSize="12"/>
        </Border>
    </Grid>
</Window>