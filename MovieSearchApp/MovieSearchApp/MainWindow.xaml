<Window x:Class="MovieSearchApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MovieSearchApp.ViewModels"
        Title="Поиск фильмов" Height="600" Width="900" WindowStartupLocation="CenterScreen">
    
        
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Стиль для кнопки -->
        <Style TargetType="Button" x:Key="SearchButtonStyle">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Адаптивный шаблон для фильма -->
        <DataTemplate x:Key="MovieTemplate">
            <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="8" Margin="10" Padding="8" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Image Source="{Binding PosterUrl}" Height="240" Stretch="Uniform" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="1" Text="{Binding Title}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap" TextAlignment="Center"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                        <TextBlock Text="{Binding Year}" Margin="0,0,10,0"/>
                        <ProgressBar Value="{Binding VoteAverage}" Maximum="10" Width="80" Height="12" Foreground="Gold"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Строка поиска -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                     Width="300" Height="30" VerticalContentAlignment="Center" Margin="0,0,10,0"
                     ToolTip="Введите название фильма"/>
            <Button Command="{Binding SearchCommand}" Style="{StaticResource SearchButtonStyle}" Content="Искать"/>
        </StackPanel>

        <!-- Анимация загрузки -->
        <Border Grid.Row="1" Background="White" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" Height="40">
            <TextBlock Text="Загрузка..." HorizontalAlignment="Center" VerticalAlignment="Center" FontStyle="Italic">
                <TextBlock.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="1" Duration="0:0:0.8" AutoReverse="True" RepeatBehavior="Forever"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TextBlock.Triggers>
            </TextBlock>
        </Border>

        <!-- Список фильмов с адаптивной раскладкой -->
        <ListBox Grid.Row="2" ItemsSource="{Binding Movies}" ItemTemplate="{StaticResource MovieTemplate}"
                 SelectionMode="Single" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Margin" Value="5"/>
                    <EventSetter Event="MouseDoubleClick" Handler="MovieDoubleClick"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" IsItemsHost="True"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
    </Grid>
</Window>