<Window x:Class="MovieSearchApp.Views.MovieDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Детали фильма" Height="550" Width="650" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,10"/>

        <!-- Основная информация -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Image Source="{Binding PosterUrl}" Width="200" HorizontalAlignment="Left" Margin="0,0,10,10"/>
                <TextBlock Text="{Binding ReleaseDate, StringFormat='Год: {0:yyyy}'}" Margin="0,5"/>
                <TextBlock Text="{Binding VoteAverage, StringFormat='Рейтинг: {0:F1} / 10'}" Margin="0,5"/>
                <TextBlock Text="Описание:" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBlock Text="{Binding Overview}" TextWrapping="Wrap"/>

                <TextBlock Text="Жанры:" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBlock Text="{Binding GenresString}" TextWrapping="Wrap"/>

                <TextBlock Text="Актёрский состав:" FontWeight="Bold" Margin="0,10,0,5"/>
                <ItemsControl ItemsSource="{Binding CastList}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Margin="0,2"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Content="Смотреть трейлер" Command="{Binding OpenTrailerCommand}" 
                        Visibility="{Binding HasTrailer, Converter={StaticResource BoolToVis}}"
                        Margin="0,15,0,0" Padding="10,5" HorizontalAlignment="Left"/>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="1" Background="#AAFFFFFF" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Загрузка..." VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20"/>
        </Grid>
    </Grid>
</Window>