<Application x:Class="StoreApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:StoreApp.Converters"
             StartupUri="Views/LoginWindow.xaml">
    <Application.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibility"/>
        <converters:DiscountToBrushConverter x:Key="DiscountToBrush"/>
        <converters:OutOfStockToBrushConverter x:Key="OutOfStockToBrush"/>
    </Application.Resources>
</Application>