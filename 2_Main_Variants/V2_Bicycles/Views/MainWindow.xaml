<Window x:Class="StoreApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление складом" 
        Height="650" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="StoreTitle" 
                           Text="Управление складом" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="White"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock x:Name="UserInfoText" 
                               Foreground="#BDC3C7" 
                               VerticalAlignment="Center" 
                               Margin="0,0,10,0"/>
                    <Button x:Name="LogoutBtn" 
                            Content="Выйти" 
                            Background="#E74C3C" 
                            Foreground="White" 
                            BorderThickness="0" 
                            Padding="10,5" 
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Панель поиска -->
        <Border Grid.Row="1" Background="White" Padding="10" Margin="0,0,0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchBox" 
                         Grid.Column="0" 
                         FontSize="14" 
                         Padding="8" 
                         Margin="0,0,10,0"
                         ToolTip="Введите название товара"/>

                <Button x:Name="SearchBtn" 
                        Grid.Column="1" 
                        Content="🔍 Поиск" 
                        Background="#3498DB" 
                        Foreground="White" 
                        Padding="15,8" 
                        Margin="0,0,10,0"
                        BorderThickness="0" 
                        Cursor="Hand"/>

                <Button x:Name="AddProductBtn" 
                        Grid.Column="2" 
                        Content="➕ Добавить товар" 
                        Background="#27AE60" 
                        Foreground="White" 
                        Padding="15,8" 
                        Margin="0,0,10,0"
                        BorderThickness="0" 
                        Cursor="Hand"
                        Visibility="Collapsed"/>

                <Button x:Name="OrdersBtn" 
                        Grid.Column="3" 
                        Content="📦 Заказы" 
                        Background="#9B59B6" 
                        Foreground="White" 
                        Padding="15,8" 
                        BorderThickness="0" 
                        Cursor="Hand"
                        Visibility="Collapsed"/>
            </Grid>
        </Border>

        <!-- Панель фильтрации -->
        <Border Grid.Row="2" Background="#ECF0F1" Padding="10" Margin="0,0,0,5" x:Name="FiltersPanel" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Категория:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox x:Name="CategoryFilter" Grid.Column="1" Margin="5" DisplayMemberPath="Name" SelectedValuePath="Id"/>

                <TextBlock Text="Производитель:" Grid.Column="2" VerticalAlignment="Center" Margin="5"/>
                <ComboBox x:Name="ManufacturerFilter" Grid.Column="3" Margin="5" DisplayMemberPath="Name" SelectedValuePath="Id"/>

                <TextBlock Text="Сортировка:" Grid.Column="4" VerticalAlignment="Center" Margin="5"/>
                <ComboBox x:Name="SortFilter" Grid.Column="5" Margin="5">
                    <ComboBoxItem Content="По умолчанию"/>
                    <ComboBoxItem Content="Цена ↑"/>
                    <ComboBoxItem Content="Цена ↓"/>
                    <ComboBoxItem Content="Кол-во ↑"/>
                    <ComboBoxItem Content="Кол-во ↓"/>
                </ComboBox>
            </Grid>
        </Border>

        <!-- Таблица товаров -->
        <DataGrid x:Name="ProductsGrid" 
                  Grid.Row="3" 
                  Margin="10" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  SelectionMode="Single"
                  RowHeight="40">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <!-- Подсветка по скидке -->
                        <DataTrigger Binding="{Binding Discount}" Value="0">
                            <Setter Property="Background" Value="{Binding Discount, Converter={StaticResource DiscountToBrush}}"/>
                        </DataTrigger>
                        <!-- Подсветка нет в наличии -->
                        <DataTrigger Binding="{Binding Quantity}" Value="0">
                            <Setter Property="Background" Value="{Binding Quantity, Converter={StaticResource OutOfStockToBrush}}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding Category.Name}" Width="120"/>
                <DataGridTextColumn Header="Производитель" Binding="{Binding Manufacturer.Name}" Width="120"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="100">
                    <DataGridTextColumn.Binding>
                        <Binding StringFormat="C2"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="80"/>
                <DataGridTextColumn Header="Скидка" Binding="{Binding Discount}" Width="80">
                    <DataGridTextColumn.Binding>
                        <Binding StringFormat="{}{0}%"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Итоговая" Binding="{Binding FinalPrice}" Width="100">
                    <DataGridTextColumn.Binding>
                        <Binding StringFormat="C2"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="Действия" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="✏️" 
                                        Command="{Binding DataContext.EditProductCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Background="#F39C12"
                                        Foreground="White"
                                        Width="35"
                                        Margin="2"
                                        Cursor="Hand"
                                        Visibility="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibility}}"/>
                                <Button Content="🗑️" 
                                        Command="{Binding DataContext.DeleteProductCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Background="#E74C3C"
                                        Foreground="White"
                                        Width="35"
                                        Margin="2"
                                        Cursor="Hand"
                                        Visibility="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibility}}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Статус бар -->
        <Border Grid.Row="5" Background="#34495E" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Text="Готово" Foreground="White"/>
                <TextBlock x:Name="StatsText" Grid.Column="1" Foreground="#BDC3C7"/>
            </Grid>
        </Border>
    </Grid>
</Window>