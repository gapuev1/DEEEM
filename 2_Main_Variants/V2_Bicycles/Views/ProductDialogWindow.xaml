<Window x:Class="StoreApp.Views.ProductDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар" 
        Height="500" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Background="#ECF0F1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Информация о товаре" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <TextBlock Grid.Row="1" Text="Название:" FontWeight="Bold" Margin="0,5"/>
            <TextBox x:Name="NameBox" Grid.Row="2" Margin="0,0,0,10" Padding="8"/>

            <TextBlock Grid.Row="3" Text="Категория:" FontWeight="Bold" Margin="0,5"/>
            <ComboBox x:Name="CategoryBox" Grid.Row="4" Margin="0,0,0,10" Padding="8" DisplayMemberPath="Name" SelectedValuePath="Id"/>

            <TextBlock Grid.Row="5" Text="Производитель:" FontWeight="Bold" Margin="0,5"/>
            <ComboBox x:Name="ManufacturerBox" Grid.Row="6" Margin="0,0,0,10" Padding="8" DisplayMemberPath="Name" SelectedValuePath="Id"/>

            <Grid Grid.Row="7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Цена:" FontWeight="Bold" Margin="0,5"/>
                <TextBlock Grid.Column="1" Text="Кол-во:" FontWeight="Bold" Margin="0,5" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="Скидка %:" FontWeight="Bold" Margin="0,5" HorizontalAlignment="Right"/>
            </Grid>

            <Grid Grid.Row="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="PriceBox" Grid.Column="0" Margin="0,0,10,10" Padding="8"/>
                <TextBox x:Name="QuantityBox" Grid.Column="1" Margin="0,0,10,10" Padding="8"/>
                <TextBox x:Name="DiscountBox" Grid.Column="2" Margin="0,0,0,10" Padding="8" Text="0"/>
            </Grid>

            <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button x:Name="SaveBtn" Content="Сохранить" Background="#27AE60" Foreground="White" Padding="30,10" Margin="10" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="CancelBtn" Content="Отмена" Background="#95A5A6" Foreground="White" Padding="30,10" Margin="10" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>