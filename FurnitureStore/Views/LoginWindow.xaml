<Window x:Class="FurnitureStore.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация" 
        Height="400" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Calibri">

    <Grid Background="#FFFFFF">
        <Grid Width="350" Height="280">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="1" Text="🪑 МЕБЕЛЬОРГ" 
                       FontSize="22" FontWeight="Bold" 
                       Foreground="#0000FF" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,5"/>

            <TextBlock Grid.Row="2" Text="Вход в систему" 
                       FontSize="14" 
                       Foreground="#333" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,25"/>

            <TextBox x:Name="LoginBox" 
                     Grid.Row="3"
                     FontSize="14"
                     Padding="12"
                     Margin="0,5"
                     Background="#FFFFFF"
                     BorderBrush="#00FFFF"
                     BorderThickness="1"
                     Foreground="#333"/>

            <PasswordBox x:Name="PasswordBox" 
                         Grid.Row="4"
                         FontSize="14"
                         Padding="12"
                         Margin="0,5"
                         Background="#FFFFFF"
                         BorderBrush="#00FFFF"
                         BorderThickness="1"/>

            <Button x:Name="LoginBtn" 
                    Grid.Row="5"
                    Content="ВОЙТИ"
                    FontSize="16"
                    FontWeight="Bold"
                    Background="#0000FF"
                    Foreground="White"
                    Padding="12"
                    Margin="0,20,0,5"
                    BorderThickness="0"
                    Cursor="Hand"/>

            <Button x:Name="GuestBtn" 
                    Grid.Row="6"
                    Content="ПРОДОЛЖИТЬ КАК ГОСТЬ"
                    FontSize="12"
                    Background="Transparent"
                    Foreground="#666"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,5,0,0"/>

            <TextBlock x:Name="ErrorText" 
                       Grid.Row="7"
                       Foreground="#E74C3C"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0"
                       Visibility="Collapsed"
                       FontSize="12"/>
        </Grid>
    </Grid>
</Window>