<Window x:Class="FurnitureStore.Views.ProductDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар" 
        Height="650" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Calibri">

    <Grid Background="#00FFFF">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Информация о товаре" FontSize="18" FontWeight="Bold" Foreground="#0000FF" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <!-- Фото товара -->
                <TextBlock Grid.Row="1" Text="Фото товара:" FontWeight="Bold" Foreground="#0000FF" Margin="0,5"/>
                <Grid Grid.Row="2" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="100" Height="100" Background="#FFFFFF" BorderBrush="#0000FF" BorderThickness="1" CornerRadius="5" Margin="0,0,10,0">
                        <Image x:Name="PreviewImage" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <Button x:Name="SelectImageBtn" Content="📁 Выбрать фото" Width="150" Height="35" Background="#0000FF" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,0,10"/>
                        <TextBlock x:Name="FileNameText" FontSize="10" Foreground="#0000FF" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>

                <!-- Артикул -->
                <TextBlock Grid.Row="3" Text="Артикул:" FontWeight="Bold" Foreground="#0000FF" Margin="0,5"/>
                <TextBox x:Name="ArticleBox" Grid.Row="4" Margin="0,0,0,10" Padding="8"/>

                <!-- Название -->
                <TextBlock Grid.Row="5" Text="Название:" FontWeight="Bold" Foreground="#0000FF" Margin="0,5"/>
                <TextBox x:Name="NameBox" Grid.Row="6" Margin="0,0,0,10" Padding="8"/>

                <!-- Категория -->
                <TextBlock Grid.Row="7" Text="Категория:" FontWeight="Bold" Foreground="#0000FF" Margin="0,5"/>
                <ComboBox x:Name="CategoryBox" Grid.Row="8" Margin="0,0,0,10" Padding="8" DisplayMemberPath="Name" SelectedValuePath="Id"/>

                <!-- Производитель -->
                <TextBlock Grid.Row="9" Text="Производитель:" FontWeight="Bold" Foreground="#0000FF" Margin="0,5"/>
                <ComboBox x:Name="ManufacturerBox" Grid.Row="10" Margin="0,0,0,10" Padding="8" DisplayMemberPath="Name" SelectedValuePath="Id"/>

                <!-- Поставщик -->
                <TextBlock Grid.Row="11" Text="Поставщик:" FontWeight="Bold" Foreground="#0000FF" Margin="0,5"/>
                <ComboBox x:Name="SupplierBox" Grid.Row="12" Margin="0,0,0,10" Padding="8" DisplayMemberPath="Name" SelectedValuePath="Id"/>

                <!-- Описание -->
                <TextBlock Grid.Row="13" Text="Описание:" FontWeight="Bold" Foreground="#0000FF" Margin="0,5"/>
                <TextBox x:Name="DescriptionBox" Grid.Row="14" Margin="0,0,0,10" Padding="8" Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>

                <!-- Цена, количество, скидка -->
                <Grid Grid.Row="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Цена:" FontWeight="Bold" Foreground="#0000FF" Margin="0,5"/>
                    <TextBlock Grid.Column="1" Text="Кол-во:" FontWeight="Bold" Foreground="#0000FF" Margin="0,5" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="Скидка %:" FontWeight="Bold" Foreground="#0000FF" Margin="0,5" HorizontalAlignment="Right"/>
                </Grid>

                <Grid Grid.Row="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PriceBox" Grid.Column="0" Margin="0,0,10,10" Padding="8"/>
                    <TextBox x:Name="QuantityBox" Grid.Column="1" Margin="0,0,10,10" Padding="8"/>
                    <TextBox x:Name="DiscountBox" Grid.Column="2" Margin="0,0,0,10" Padding="8" Text="0"/>
                </Grid>

                <!-- Кнопки -->
                <StackPanel Grid.Row="17" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button x:Name="SaveBtn" Content="💾 Сохранить" Background="#0000FF" Foreground="White" Padding="30,10" Margin="10" BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="CancelBtn" Content="❌ Отмена" Background="#95A5A6" Foreground="White" Padding="30,10" Margin="10" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>