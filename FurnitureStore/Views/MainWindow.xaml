<Window x:Class="FurnitureStore.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="МебельОрг" 
        Height="650" Width="1200"
        WindowStartupLocation="CenterScreen"
        FontFamily="Calibri">

    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="#00FFFF" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Image Source="/Images/icon.png" Width="32" Height="32" Margin="0,0,10,0"/>
                    <TextBlock Text="🪑 МебельОрг" FontSize="20" FontWeight="Bold" Foreground="#0000FF"/>
                </StackPanel>

                <TextBlock x:Name="UserInfoText" Grid.Column="1" Foreground="#0000FF" VerticalAlignment="Center" Margin="0,0,15,0"/>

                <Button x:Name="LogoutBtn" Grid.Column="2" Content="Выйти" Background="#0000FF" Foreground="White" BorderThickness="0" Padding="10,5" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Панель поиска -->
        <Border Grid.Row="1" Background="#FFFFFF" Padding="10" Margin="0,0,0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchBox" Grid.Column="0" FontSize="14" Padding="8" Margin="0,0,10,0" BorderBrush="#00FFFF" BorderThickness="1"/>

                <Button x:Name="SearchBtn" Grid.Column="1" Content="🔍 Поиск" Background="#0000FF" Foreground="White" Padding="15,8" Margin="0,0,10,0" BorderThickness="0" Cursor="Hand"/>

                <Button x:Name="AddProductBtn" Grid.Column="2" Content="➕ Добавить товар" Background="#0000FF" Foreground="White" Padding="15,8" Margin="0,0,10,0" BorderThickness="0" Cursor="Hand" Visibility="Collapsed"/>

                <Button x:Name="OrdersBtn" Grid.Column="3" Content="📦 Заказы" Background="#0000FF" Foreground="White" Padding="15,8" BorderThickness="0" Cursor="Hand" Visibility="Collapsed"/>
            </Grid>
        </Border>

        <!-- Панель фильтрации -->
        <Border Grid.Row="2" Background="#00FFFF" Padding="10" Margin="0,0,0,5" x:Name="FiltersPanel" Visibility="Collapsed">
            <WrapPanel>
                <TextBlock Text="Категория:" VerticalAlignment="Center" Margin="5,0" Foreground="#0000FF"/>
                <ComboBox x:Name="CategoryFilter" Width="150" Margin="5,0" Background="#FFFFFF"/>

                <TextBlock Text="Производитель:" VerticalAlignment="Center" Margin="15,0,5,0" Foreground="#0000FF"/>
                <ComboBox x:Name="ManufacturerFilter" Width="150" Margin="5,0" Background="#FFFFFF"/>

                <TextBlock Text="Скидка:" VerticalAlignment="Center" Margin="15,0,5,0" Foreground="#0000FF"/>
                <ComboBox x:Name="DiscountFilter" Width="120" Margin="5,0" Background="#FFFFFF">
                    <ComboBoxItem Content="Все"/>
                    <ComboBoxItem Content="0-10.99%"/>
                    <ComboBoxItem Content="11-14.99%"/>
                    <ComboBoxItem Content="15% и более"/>
                </ComboBox>

                <TextBlock Text="Сортировка:" VerticalAlignment="Center" Margin="15,0,5,0" Foreground="#0000FF"/>
                <ComboBox x:Name="SortFilter" Width="120" Margin="5,0" Background="#FFFFFF">
                    <ComboBoxItem Content="По умолчанию"/>
                    <ComboBoxItem Content="Цена ↑"/>
                    <ComboBoxItem Content="Цена ↓"/>
                    <ComboBoxItem Content="Кол-во ↑"/>
                    <ComboBoxItem Content="Кол-во ↓"/>
                </ComboBox>
            </WrapPanel>
        </Border>

        <!-- Таблица товаров -->
        <DataGrid x:Name="ProductsGrid" 
                  Grid.Row="3" 
                  Margin="10" 
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  RowHeight="80">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Discount}" Value="15">
                            <Setter Property="Background" Value="#008080"/>
                            <Setter Property="Foreground" Value="White"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Discount}" Value="16">
                            <Setter Property="Background" Value="#008080"/>
                            <Setter Property="Foreground" Value="White"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Discount}" Value="17">
                            <Setter Property="Background" Value="#008080"/>
                            <Setter Property="Foreground" Value="White"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Discount}" Value="18">
                            <Setter Property="Background" Value="#008080"/>
                            <Setter Property="Foreground" Value="White"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Discount}" Value="19">
                            <Setter Property="Background" Value="#008080"/>
                            <Setter Property="Foreground" Value="White"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Discount}" Value="20">
                            <Setter Property="Background" Value="#008080"/>
                            <Setter Property="Foreground" Value="White"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Discount}" Value="22">
                            <Setter Property="Background" Value="#008080"/>
                            <Setter Property="Foreground" Value="White"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Discount}" Value="25">
                            <Setter Property="Background" Value="#008080"/>
                            <Setter Property="Foreground" Value="White"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Quantity}" Value="0">
                            <Setter Property="Background" Value="#95A5A6"/>
                            <Setter Property="Foreground" Value="White"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Фото" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding FullImagePath}" Width="60" Height="60" Stretch="UniformToFill"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" Width="100"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding Category.Name}" Width="120"/>
                <DataGridTextColumn Header="Производитель" Binding="{Binding Manufacturer.Name}" Width="120"/>
                <DataGridTextColumn Header="Поставщик" Binding="{Binding Supplier.Name}" Width="120"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=C2}" Width="100"/>
                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="80"/>
                <DataGridTextColumn Header="Скидка" Binding="{Binding Discount, StringFormat={}{0}%}" Width="80"/>
                <DataGridTextColumn Header="Итоговая" Binding="{Binding FinalPrice, StringFormat=C2}" Width="100"/>

                <DataGridTemplateColumn Header="Действия" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="✏️" 
                                        Click="EditProduct_Click" 
                                        CommandParameter="{Binding}"
                                        Background="#F39C12" 
                                        Foreground="White" 
                                        Width="35" 
                                        Margin="2" 
                                        Cursor="Hand"/>
                                <Button Content="🗑️" 
                                        Click="DeleteProduct_Click" 
                                        CommandParameter="{Binding}"
                                        Background="#E74C3C" 
                                        Foreground="White" 
                                        Width="35" 
                                        Margin="2" 
                                        Cursor="Hand"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Статус бар -->
        <Border Grid.Row="5" Background="#00FFFF" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Text="Готово" Foreground="#0000FF"/>
                <TextBlock x:Name="StatsText" Grid.Column="1" Foreground="#0000FF"/>
            </Grid>
        </Border>
    </Grid>
</Window>