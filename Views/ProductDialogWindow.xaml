<Window x:Class="ToyStore.Views.ProductDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Игрушка" 
        Height="550" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Background="#F5DEB3">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Информация об игрушке" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <TextBlock Grid.Row="1" Text="Фото:" FontWeight="Bold" Margin="0,5" Foreground="#DEB887"/>
            <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image x:Name="PreviewImage" Width="80" Height="60" Stretch="UniformToFill" Margin="0,0,10,0"/>
                <Button x:Name="SelectImageBtn" Grid.Column="1" Content="Выбрать фото" Width="120" Height="30" Background="#DEB887" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </Grid>

            <TextBlock Grid.Row="3" Text="Название:" FontWeight="Bold" Margin="0,5" Foreground="#DEB887"/>
            <TextBox x:Name="NameBox" Grid.Row="4" Margin="0,0,0,10" Padding="8"/>

            <TextBlock Grid.Row="5" Text="Категория:" FontWeight="Bold" Margin="0,5" Foreground="#DEB887"/>
            <ComboBox x:Name="CategoryBox" Grid.Row="6" Margin="0,0,0,10" Padding="8" DisplayMemberPath="Name" SelectedValuePath="Id"/>

            <TextBlock Grid.Row="7" Text="Производитель:" FontWeight="Bold" Margin="0,5" Foreground="#DEB887"/>
            <ComboBox x:Name="ManufacturerBox" Grid.Row="8" Margin="0,0,0,10" Padding="8" DisplayMemberPath="Name" SelectedValuePath="Id"/>

            <TextBlock Grid.Row="9" Text="Поставщик:" FontWeight="Bold" Margin="0,5" Foreground="#DEB887"/>
            <ComboBox x:Name="SupplierBox" Grid.Row="10" Margin="0,0,0,10" Padding="8" DisplayMemberPath="Name" SelectedValuePath="Id"/>

            <TextBlock Grid.Row="11" Text="Описание:" FontWeight="Bold" Margin="0,5" Foreground="#DEB887"/>
            <TextBox x:Name="DescriptionBox" Grid.Row="12" Margin="0,0,0,10" Padding="8" Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>

            <Grid Grid.Row="13">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Цена:" FontWeight="Bold" Margin="0,5" Foreground="#DEB887"/>
                <TextBlock Grid.Column="1" Text="Кол-во:" FontWeight="Bold" Margin="0,5" HorizontalAlignment="Center" Foreground="#DEB887"/>
                <TextBlock Grid.Column="2" Text="Скидка %:" FontWeight="Bold" Margin="0,5" HorizontalAlignment="Right" Foreground="#DEB887"/>
            </Grid>

            <Grid Grid.Row="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="PriceBox" Grid.Column="0" Margin="0,0,10,10" Padding="8"/>
                <TextBox x:Name="QuantityBox" Grid.Column="1" Margin="0,0,10,10" Padding="8"/>
                <TextBox x:Name="DiscountBox" Grid.Column="2" Margin="0,0,0,10" Padding="8" Text="0"/>
            </Grid>

            <StackPanel Grid.Row="15" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button x:Name="SaveBtn" Content="Сохранить" Background="#27AE60" Foreground="White" Padding="30,10" Margin="10" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="CancelBtn" Content="Отмена" Background="#95A5A6" Foreground="White" Padding="30,10" Margin="10" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>